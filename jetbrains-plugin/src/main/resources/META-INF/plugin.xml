<idea-plugin>
    <id>com.jasperpotts.drawdsl.editor</id>
    <name>Draw DSL Editor</name>
    <vendor url="https://github.com/jasperpotts">Jasper Potts</vendor>

    <description><![CDATA[
        Custom editor for .drawio.svg and .drawio.png diagram files using the Draw DSL format.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.DrawDslBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="DrawDSL Diagram"
                implementationClass="com.jasperpotts.drawdsl.editor.DrawDslFileType"
                fieldName="INSTANCE"/>
        <fileTypeMapping pattern="*.drawio.svg" type="DrawDSL Diagram"/>
        <fileTypeMapping pattern="*.drawio.png" type="DrawDSL Diagram"/>

        <fileEditorProvider
                implementation="com.jasperpotts.drawdsl.editor.editor.DrawDslEditorProvider"/>
    </extensions>
</idea-plugin>
